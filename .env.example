# ─── GitHub Database ──────────────────────────────────────────────────────────
# Personal Access Token (repo:write scope)
GITHUB_TOKEN=ghp_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# GitHub username or organization
GITHUB_OWNER=your-github-username

# Private repository name (create: dee-database)
GITHUB_REPO=dee-database

# Branch to use
GITHUB_BRANCH=main

# ─── Authentication ───────────────────────────────────────────────────────────
# Long random string for JWT signing (min 32 chars)
JWT_SECRET=your-super-long-random-secret-string-here-minimum-32-chars

# ─── Vercel Blob Storage ──────────────────────────────────────────────────────
# Get from Vercel Dashboard > Storage > Blob
BLOB_READ_WRITE_TOKEN=vercel_blob_rw_xxxxxxxxxxxxxxxxxxxx

# ─── Initial Setup ────────────────────────────────────────────────────────────
# Token to call /api/admin/setup (one-time initialization)
SETUP_TOKEN=your-one-time-setup-token

# Initial superadmin password (change immediately after setup!)
INITIAL_ADMIN_PASSWORD=ChangeMeImmediately123!
