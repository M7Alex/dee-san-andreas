{
  "functions": {
    "app/api/**": {
      "maxDuration": 30
    }
  },
  "ignoreCommand": "git diff --name-only HEAD^ HEAD | grep -qvE '^db/' && echo 1 || echo 0",
  "headers": [
    {
      "source": "/api/(.*)",
      "headers": [
        { "key": "X-Content-Type-Options", "value": "nosniff" },
        { "key": "X-Frame-Options", "value": "DENY" },
        { "key": "X-XSS-Protection", "value": "1; mode=block" }
      ]
    }
  ]
}
