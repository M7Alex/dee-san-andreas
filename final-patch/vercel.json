{
  "github": {
    "silent": true,
    "autoJobCancelation": true
  },
  "ignoreCommand": "git log -1 --pretty=%B | grep -qE '^\\[db\\]'",
  "functions": {
    "app/api/**": {
      "maxDuration": 30
    }
  },
  "headers": [
    {
      "source": "/api/(.*)",
      "headers": [
        { "key": "X-Content-Type-Options", "value": "nosniff" },
        { "key": "X-Frame-Options", "value": "DENY" },
        { "key": "X-XSS-Protection", "value": "1; mode=block" }
      ]
    }
  ]
}
